# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/estoque

# JWT Secret for authentication
JWT_SECRET=minhasuperchavesegura

# Google OAuth Client ID (optional - for Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Stripe Configuration (Required for payments/subscriptions)
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_price_id_here

# Resend Email Configuration (Required for email verification/reset)
# Get your API key from: https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
SMTP_FROM=noreply@mail.coderonin.com.br

# Frontend URL (for redirects after payment)
FRONTEND_URL=http://localhost:5173

# Node Environment
NODE_ENV=development

# Server Port
PORT=3000

# =============================================================================
# SENTRY MONITORING (Required for error tracking)
# =============================================================================
# Get your DSN from: https://sentry.io/settings/projects/your-backend/keys/
# Format: https://<public_key>@<domain>.ingest.sentry.io/<project_id>
# IMPORTANT: This is a SECRET - NEVER commit real DSN to GitHub!
SENTRY_DSN=https://examplekey@o0.ingest.sentry.io/0
